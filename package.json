{
  "name": "lime-csr-js",
  "version": "0.1.2",
  "description": "Client-side rendering with pure javascript with W3 Standarts",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "html-first",
    "client-side-rendering",
    "reactive",
    "no-build"
  ],
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js --bundle --minify --format=esm --outfile=dist/index.min.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
